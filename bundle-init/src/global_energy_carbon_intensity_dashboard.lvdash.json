{
  "datasets": [
    {
      "columns": [
        {
          "description": "Sum of all renewable energy source shares",
          "displayName": "Renewables Total %",
          "expression": "SUM(COALESCE(CAST(`Bioenergy` AS DOUBLE), CAST(0 AS DOUBLE)) + COALESCE(CAST(`Hydro` AS DOUBLE), CAST(0 AS DOUBLE)) + COALESCE(CAST(`Other renewables` AS DOUBLE), CAST(0 AS DOUBLE)) + COALESCE(CAST(`Solar` AS DOUBLE), CAST(0 AS DOUBLE)) + COALESCE(CAST(`Wind` AS DOUBLE), CAST(0 AS DOUBLE)))"
        }
      ],
      "displayName": "Energy Generation Share by Country",
      "name": "482f1056",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      country_name,\n",
        "      country_code,\n",
        "      energy_source,\n",
        "      share_of_generation_pct, \n",
        "      date\n",
        "    FROM\n",
        "      energy_trans_dev.gold.gold_energy_generation_share\n",
        "  )\n",
        "    PIVOT (\n",
        "      AVG(share_of_generation_pct) FOR energy_source IN (\n",
        "        'Bioenergy',\n",
        "        'Coal',\n",
        "        'Gas',\n",
        "        'Hydro',\n",
        "        'Net imports',\n",
        "        'Nuclear',\n",
        "        'Other fossil',\n",
        "        'Other renewables',\n",
        "        'Solar',\n",
        "        'Wind'\n",
        "      )\n",
        "    )"
      ]
    },
    {
      "catalog": "energy_trans_dev",
      "displayName": "Global Trends in Country Level Carbon Intensity",
      "name": "fcb33aee",
      "queryLines": [
        "-- Which countries have the highest CO2 intensity trends?\n",
        "WITH country_years AS (\n",
        "  SELECT\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    `year`,\n",
        "    `co2_intensity_gco2_per_kwh`\n",
        "  FROM `energy_trans_dev`.`gold`.`gold_energy_profile`\n",
        "  WHERE `co2_intensity_gco2_per_kwh` IS NOT NULL\n",
        "),\n",
        "bounds AS (\n",
        "  SELECT\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    MIN(`year`) AS first_year,\n",
        "    MAX(`year`) AS last_year\n",
        "  FROM country_years\n",
        "  GROUP BY `country_name`, `country_code`\n",
        "),\n",
        "trend AS (\n",
        "  SELECT\n",
        "    b.`country_name`,\n",
        "    b.`country_code`,\n",
        "    b.first_year,\n",
        "    b.last_year,\n",
        "    FIRST_VALUE(c.`co2_intensity_gco2_per_kwh`) \n",
        "      OVER (PARTITION BY b.`country_name`, b.`country_code` ORDER BY c.`year` ASC \n",
        "            ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS first_intensity,\n",
        "    FIRST_VALUE(c.`co2_intensity_gco2_per_kwh`) \n",
        "      OVER (PARTITION BY b.`country_name`, b.`country_code` ORDER BY c.`year` DESC \n",
        "            ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS last_intensity\n",
        "  FROM bounds b\n",
        "  JOIN country_years c\n",
        "    ON b.`country_name` = c.`country_name`\n",
        "   AND b.`country_code` = c.`country_code`\n",
        "),\n",
        "country_trend AS (\n",
        "  SELECT DISTINCT\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    first_year,\n",
        "    last_year,\n",
        "    first_intensity,\n",
        "    last_intensity,\n",
        "    last_intensity - first_intensity AS abs_change_intensity,\n",
        "    CASE \n",
        "      WHEN first_intensity = 0 THEN NULL\n",
        "      ELSE (last_intensity - first_intensity) / first_intensity * 100.0\n",
        "    END AS pct_change_intensity\n",
        "  FROM trend\n",
        ")\n",
        "SELECT\n",
        "  `country_name`,\n",
        "  `country_code`,\n",
        "  first_year,\n",
        "  last_year,\n",
        "  first_intensity AS initial_co2_intensity_gco2_per_kwh,\n",
        "  last_intensity AS latest_co2_intensity_gco2_per_kwh,\n",
        "  abs_change_intensity AS change_gco2_per_kwh,\n",
        "  pct_change_intensity AS pct_change_gco2_per_kwh\n",
        "FROM country_trend\n",
        "ORDER BY latest_co2_intensity_gco2_per_kwh DESC, pct_change_intensity DESC\n",
        "LIMIT 20;"
      ],
      "schema": "gold"
    },
    {
      "displayName": "Global Average COâ‚‚ Intensity Over Time",
      "name": "global_avg_co2",
      "queryLines": [
        "SELECT\n",
        "  `year`,\n",
        "  `co2_intensity_gco2_per_kwh`\n",
        "FROM\n",
        "  `energy_trans_dev`.`gold`.`gold_energy_profile`\n",
        "WHERE\n",
        "  `co2_intensity_gco2_per_kwh` IS NOT NULL"
      ]
    },
    {
      "displayName": "Renewable Energy Share Impact on Economic Growth Trends",
      "name": "fc2d4794",
      "queryLines": [
        "-- How does GDP growth differ by renewable share_of_generation_pct levels?\n",
        "SELECT\n",
        "  CASE\n",
        "    WHEN `share_of_generation_pct` < 20 THEN '0-20%'\n",
        "    WHEN `share_of_generation_pct` < 40 THEN '20-40%'\n",
        "    WHEN `share_of_generation_pct` < 60 THEN '40-60%'\n",
        "    WHEN `share_of_generation_pct` < 80 THEN '60-80%'\n",
        "    ELSE '80-100%'\n",
        "  END AS `renewable_share_bucket`,\n",
        "  COUNT(*) AS `num_country_years`,\n",
        "  AVG(`share_of_generation_pct`) AS `avg_share_of_generation_pct`,\n",
        "  AVG(`gdp_growth_pct`) AS `avg_gdp_growth_pct`\n",
        "FROM `energy_trans_dev`.`gold`.`gold_growth_transition`\n",
        "WHERE `share_of_generation_pct` IS NOT NULL\n",
        "  AND `gdp_growth_pct` IS NOT NULL\n",
        "GROUP BY\n",
        "  CASE\n",
        "    WHEN `share_of_generation_pct` < 20 THEN '0-20%'\n",
        "    WHEN `share_of_generation_pct` < 40 THEN '20-40%'\n",
        "    WHEN `share_of_generation_pct` < 60 THEN '40-60%'\n",
        "    WHEN `share_of_generation_pct` < 80 THEN '60-80%'\n",
        "    ELSE '80-100%'\n",
        "  END\n",
        "ORDER BY `renewable_share_bucket`;"
      ]
    },
    {
      "displayName": "Energy Access Disparity Overview Dataset",
      "name": "4c02f2de",
      "queryLines": [
        "select * from energy_trans_dev.gold.gold_access_gap"
      ]
    },
    {
      "displayName": "Clean Energy Transition Leaders",
      "name": "clean_energy_transition",
      "queryLines": [
        "WITH monthly_renewable AS (\n",
        "  SELECT\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    `date`,\n",
        "    YEAR(`date`) AS `year`,\n",
        "    SUM(`share_of_generation_pct`) AS `monthly_renewable_pct`\n",
        "  FROM\n",
        "    `energy_trans_dev`.`gold`.`gold_energy_generation_share`\n",
        "  WHERE\n",
        "    `energy_source` IN ('Bioenergy', 'Hydro', 'Other renewables', 'Solar', 'Wind')\n",
        "  GROUP BY\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    `date`,\n",
        "    YEAR(`date`)\n",
        "),\n",
        "yearly_renewable AS (\n",
        "  SELECT\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    `year`,\n",
        "    AVG(`monthly_renewable_pct`) AS `avg_renewable_pct`\n",
        "  FROM\n",
        "    monthly_renewable\n",
        "  GROUP BY\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    `year`\n",
        "),\n",
        "bounds AS (\n",
        "  SELECT\n",
        "    `country_name`,\n",
        "    `country_code`,\n",
        "    MIN(`year`) AS `first_year`,\n",
        "    MAX(`year`) AS `last_year`\n",
        "  FROM\n",
        "    yearly_renewable\n",
        "  GROUP BY\n",
        "    `country_name`,\n",
        "    `country_code`\n",
        "),\n",
        "transition AS (\n",
        "  SELECT\n",
        "    b.`country_name`,\n",
        "    b.`country_code`,\n",
        "    b.`first_year`,\n",
        "    b.`last_year`,\n",
        "    ROUND(fy.`avg_renewable_pct`, 2) AS `initial_renewable_pct`,\n",
        "    ROUND(ly.`avg_renewable_pct`, 2) AS `latest_renewable_pct`,\n",
        "    ROUND(ly.`avg_renewable_pct` - fy.`avg_renewable_pct`, 2) AS `renewable_share_change_pp`\n",
        "  FROM\n",
        "    bounds b\n",
        "      JOIN yearly_renewable fy\n",
        "        ON b.`country_name` = fy.`country_name`\n",
        "        AND b.`country_code` = fy.`country_code`\n",
        "        AND b.`first_year` = fy.`year`\n",
        "      JOIN yearly_renewable ly\n",
        "        ON b.`country_name` = ly.`country_name`\n",
        "        AND b.`country_code` = ly.`country_code`\n",
        "        AND b.`last_year` = ly.`year`\n",
        ")\n",
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  transition\n",
        "ORDER BY\n",
        "  `renewable_share_change_pp` DESC\n",
        "LIMIT 20"
      ]
    },
